{
  "version": "1.0",
  "module": "TQF-06.4.1 Literary Style Rules Engine",
  "target": "台灣繁體中文出版級小說敘事",
  "principles": [
    "忠實原文，不新增劇情。",
    "提升小說閱讀感，但不得改變事件、人物關係與語義。",
    "保留心理描寫、停頓、動作順序、場景氛圍與比喻。",
    "避免機械直譯、說明文語氣與摘要化。",
    "中文可自然展開韓文壓縮語序。"
  ],
  "rewrite_preferences": [
    {
      "avoid": "他感到不安。",
      "prefer": "他心底那股不祥的預感又沉了幾分。"
    },
    {
      "avoid": "他看著男人。",
      "prefer": "他沉默地望了男人一會兒。"
    },
    {
      "avoid": "他說道。",
      "prefer": "他開口、低聲說、淡淡地問、嘀咕，依語境選擇。"
    },
    {
      "avoid": "事情很糟。",
      "prefer": "情況顯然不太妙。"
    }
  ],
  "rules": [
    {
      "id": "LIT_PSYCHOLOGY",
      "triggers": ["예감", "기분", "생각", "불길", "우울", "난감"],
      "instruction": "本段包含心理描寫，譯文需保留情緒層次，不可壓成一句概括。"
    },
    {
      "id": "LIT_ACTION_SEQUENCE",
      "triggers": ["떨어져", "굴렀다", "멈칫", "비켜섰다", "두드리며"],
      "instruction": "本段包含動作順序，譯文需保留動作過程與畫面感，不可只翻結果。"
    },
    {
      "id": "LIT_ATMOSPHERE",
      "triggers": ["비", "궂은", "소리 없이", "희미하게", "하늘"],
      "instruction": "本段包含場景氛圍，譯文需保留天氣、聲音、空間與氣氛。"
    },
    {
      "id": "LIT_METAPHOR",
      "triggers": ["역병신", "처럼", "다를 바 없는"],
      "instruction": "本段包含比喻或意象，譯文需保留文學效果，不可攤平成普通敘述。"
    },
    {
      "id": "LIT_DIALOGUE_BEAT",
      "triggers": ["말했다", "물었다", "중얼거렸다", "웃었다", "노려보았다"],
      "instruction": "本段包含對話節奏，譯文需保留說話前後的停頓、表情、動作與語氣。"
    }
  ],
  "forbidden": [
    "把內心戲改成客觀說明。",
    "把短句全部合併成長句。",
    "刪除省略號、停頓或沉默。",
    "把比喻改成普通描述。",
    "為了文學化而新增原文沒有的情節。"
  ]
}